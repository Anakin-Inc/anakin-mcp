{
  "name": "@anakin-io/mcp",
  "version": "0.1.3",
  "description": "Model Context Protocol server for Anakin (anakin.io) — gives AI agents in Claude Desktop, Cursor, Windsurf, VS Code, and other MCP-compatible clients native access to web scraping, search, crawling, mapping, agentic research, and Wire actions.",
  "license": "Apache-2.0",
  "homepage": "https://anakin.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anakin-Inc/anakin-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Anakin-Inc/anakin-mcp/issues"
  },
  "keywords": [
    "anakin",
    "mcp",
    "model-context-protocol",
    "scraping",
    "web-scraper",
    "crawler",
    "search",
    "ai-agent",
    "claude",
    "cursor",
    "windsurf"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/cli.cjs",
  "module": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "anakin-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.3.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
